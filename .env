# .env file for environment variables

# Chunking configuration
CHUNK_SIZE = 400
CHUNK_OVERLAP = 50

# Database configuration
DB_PATH=./chroma_db
COLLECTION_NAME=sec_10k


# Ollama API configuration
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:3b

# Model configuration
TEMPERATURE=0.1
MAX_TOKENS=2048